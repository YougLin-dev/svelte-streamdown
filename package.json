{
	"name": "@youglin/svelte-streamdown",
	"version": "3.1.0-perf.3",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"test:ui": "vitest --ui",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./code": {
			"types": "./dist/Elements/Code.svelte.d.ts",
			"svelte": "./dist/Elements/Code.svelte"
		},
		"./mermaid": {
			"types": "./dist/Elements/Mermaid.svelte.d.ts",
			"svelte": "./dist/Elements/Mermaid.svelte"
		},
		"./math": {
			"types": "./dist/Elements/Math.svelte.d.ts",
			"svelte": "./dist/Elements/Math.svelte"
		}
	},
	"peerDependencies": {
		"svelte": "^5.54.1"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260317.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@vitest/browser": "^4.1.0",
		"@vitest/browser-playwright": "^4.1.0",
		"@vitest/ui": "^4.1.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"publint": "^0.3.18",
		"stick-to-bottom-svelte": "^1.0.2",
		"svelte": "^5.54.1",
		"svelte-check": "^4.4.5",
		"svelte-themes": "^2.0.10",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vite": "^8.0.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.1.0",
		"wrangler": "^4.76.0"
	},
	"license": "MIT",
	"keywords": [
		"svelte"
	],
	"pnpm": {
		"onlyBuiltDependencies": [
			"@tailwindcss/oxide",
			"esbuild",
			"sharp",
			"workerd"
		]
	},
	"dependencies": {
		"@floating-ui/dom": "^1.7.6",
		"@shikijs/langs": "^4.0.2",
		"@shikijs/themes": "^4.0.2",
		"clsx": "^2.1.1",
		"katex": "^0.16.40",
		"marked": "^17.0.5",
		"mermaid": "^11.13.0",
		"shiki": "^4.0.2",
		"tailwind-merge": "^3.5.0"
	}
}
